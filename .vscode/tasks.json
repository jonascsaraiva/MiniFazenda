{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Limpar build",
            "type": "shell",
            "command": "if exist build rmdir /s /q build",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/d", "/c"]
                }
            },
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Configurar CMake MiniFazenda2",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/cmake.exe",
            "args": [
                "-S",
                ".",
                "-B",
                "build",
                "-G",
                "Ninja",
                "-DCMAKE_PREFIX_PATH=C:/msys64/ucrt64",
                "-DCMAKE_C_COMPILER=C:/msys64/ucrt64/bin/gcc.exe",
                "-DCMAKE_CXX_COMPILER=C:/msys64/ucrt64/bin/g++.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/d", "/c"]
                }
            },
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Build MiniFazenda2",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/ninja.exe",
            "options": {
                "cwd": "${workspaceFolder}/build",
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/d", "/c"]
                }
            },
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Rodar MiniFazenda2",
            "type": "shell",
            "command": ".\\bin\\MiniFazenda2.exe",
            "options": {
                "cwd": "${workspaceFolder}/build",
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/d", "/c"]
                }
            },
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Clean Rebuild & Run MiniFazenda2",
            "type": "shell",
            "command": "echo MiniFazenda2 finalizado.",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Limpar build",
                "Configurar CMake MiniFazenda2",
                "Build MiniFazenda2",
                "Rodar MiniFazenda2"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/d", "/c"]
                }
            },
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Build & Run MiniFazenda2 sem limpar",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/ninja.exe && .\\bin\\MiniFazenda2.exe",
            "options": {
                "cwd": "${workspaceFolder}/build",
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/d", "/c"]
                }
            },
            "dependsOn": [
                "Configurar CMake MiniFazenda2"
            ],
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}
